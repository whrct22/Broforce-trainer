      <Description>"技能人造指针"</Description>
      <VariableType>Auto Assembler Script</VariableType>
      <AssemblerScript>{ Game   : Broforce
  Version: 
  Date   : 2026-07-15
  Author : ������

  This script does blah blah blah
}

[ENABLE]

aobscan(INJECT,89 87 DC 05 00 00) // should be unique
alloc(newmem,$1000,INJECT)
alloc(player_base_address,2048)
label(code)
label(return)
registersymbol(player_base_address)
newmem:
  cmp [rdi+104],1
  je player_process
  nop
  jmp return

player_process:
  mov [player_base_address],rdi
  mov [rdi+000005DC],eax
  jmp return
code:
  mov [rdi+000005DC],eax
  jmp return

INJECT:
  jmp newmem
  nop
return:
registersymbol(INJECT)

[DISABLE]

INJECT:
  db 89 87 DC 05 00 00

unregistersymbol(INJECT)
unregistersymbol(player_base_address)
dealloc(newmem)
dealloc(player_base_address)
